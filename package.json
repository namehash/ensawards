{
  "name": "ensawards-monorepo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "lint": "pnpm -r --parallel --aggregate-output lint && biome check --write",
    "lint:ci": "pnpm -r --parallel --aggregate-output lint:ci && biome ci",
    "typecheck": "pnpm -r --parallel --aggregate-output typecheck",
    "test": "vitest --silent passed-only",
    "test:cache": "pnpm test -t 'CachedIdentity'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "baseline-browser-mapping": "^2.9.19",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "vite@<7.3.1": ">=7.3.1 <8.0.0",
      "tar@<7.5.11": ">=7.5.11 <8.0.0",
      "lodash@<4.17.23": ">=4.17.23",
      "ajv@<8.18.0": ">=8.18.0 <9.0.0",
      "minimatch@<10.2.3": ">=10.2.3 <11.0.0",
      "rollup@<4.59.0": ">=4.59.0 <5.0.0",
      "svgo@<4.0.1": ">=4.0.1 <5.0.0",
      "devalue@<5.6.4": ">=5.6.4 <6.0.0",
      "path-to-regexp@<6.3.0": ">=6.3.0 <7.0.0"
    }
  }
}
