{
  "name": "ensawards-monorepo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "lint": "pnpm -r --parallel --aggregate-output lint && biome check --write",
    "lint:ci": "pnpm -r --parallel --aggregate-output lint:ci && biome ci",
    "typecheck": "pnpm -r --parallel --aggregate-output typecheck",
    "test": "vitest --silent passed-only",
    "test:cache": "pnpm test -t 'CachedIdentity'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "baseline-browser-mapping": "^2.9.19",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "lodash@<4.18.0": ">=4.18.0 <5.0.0",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3 <3.0.0",
      "postcss@<8.5.10": ">=8.5.10 <9.0.0"
    }
  }
}
