---
import { APPS } from "data/apps";
import { BenchmarkStatuses } from "data/apps/benchmarks-types.ts";
import type { BestPracticeApp } from "data/ens-best-practices/types.ts";
import { cn } from "@/utils/tailwindClassConcatenation";
import SubpageHero from "../molecules/SubpageHero.astro";
import { calculateAppSupport } from "data/apps/utils.ts";
import {
  allBenchmarksPending as allBenchmarksPendingUtil,
  compareBenchmarks,
} from "data/apps/benchmarks-utils";
import { SuggestionCard, SuggestionCardLoading } from "../atoms/cards/SuggestionCard.tsx";
import BestPracticeTechnicalDetails from "@/components/molecules/BestPracticeTechnicalDetails.astro";
import { BenchmarksPerAppTypeCard } from "@/components/atoms/cards/BenchmarksPerAppTypeCard.tsx";
import { ScoreBar } from "@/components/atoms/ens-awards-score/bar.tsx";
import { type Contribution } from "data/contributors/types";
import { AppliesToBadges } from "@/components/atoms/badges/AppliesToBadges.tsx";

export interface AppBestPracticeDetailsProps {
  bestPractice: BestPracticeApp;
}

const { bestPractice }: AppBestPracticeDetailsProps = Astro.props;

// Get apps that have benchmarks for this specific best practice
const appsWithBenchmarks = APPS.map((app) => {
  const matchingBenchmark = app.benchmarks.find(
    (benchmark) =>
      benchmark.bestPractice.category.id === bestPractice.category.id &&
      benchmark.bestPractice.id === bestPractice.id,
  );

  return {
    app,
    benchmark: matchingBenchmark,
  };
});

// Filter out apps that don't have a benchmark for this best practice
const appsWithValidBenchmarks = appsWithBenchmarks.filter(
  ({ benchmark }) => benchmark !== undefined,
);

// Sort benchmark results
const sortedAppsByBenchmark = appsWithValidBenchmarks.sort((a, b) => {
  // First try to differentiate by benchmarks
  const benchmarksDiff = compareBenchmarks(a.benchmark, b.benchmark);

  if (benchmarksDiff !== 0) return benchmarksDiff;

  // Otherwise, sort alphabetically by App name
  return a.app.name.localeCompare(b.app.name);
});

const appSupport = calculateAppSupport(bestPractice);

const benchmarkDataContributions: Contribution[] = appsWithValidBenchmarks
  .filter(
    ({ benchmark }): benchmark is AppBenchmarkCompleted =>
      benchmark.status === BenchmarkStatuses.Completed,
  )
  .flatMap(({ benchmark }) => benchmark.contributions);
const allContributions: Contribution[] = [
  ...bestPractice.contributions,
  ...benchmarkDataContributions,
];

const allBenchmarksPending = allBenchmarksPendingUtil(
  appsWithValidBenchmarks.map(({ benchmark }) => benchmark),
);

const additionalInfoContainerStyles =
  "flex flex-row md:flex-col flex-nowrap justify-between md:justify-center items-center md:items-end md:gap-0 leading-7 max-md:self-stretch";
---

<SubpageHero
  header={bestPractice.name}
  description={bestPractice.description}
  breadcrumbs={[
    { text: "ENS best practices", linkHref: "/ens-best-practices" },
    { text: bestPractice.category.name },
  ]}
  additionalElements={[
    {
      name: "Category",
      value: bestPractice.category.name,
    },
  ]}
  styles={{
    textContentContainer: "md:max-w-[720px]",
    additionalElementsContainer:
      "md:max-[1200px]:flex-col min-[1200px]:flex-row md:gap-8 xl:gap-14",
  }}>
  <Fragment slot="extraAdditionalElementLast">
    <div class={cn(additionalInfoContainerStyles, "md:gap-0.5 md:items-start")}>
      <p class="text-gray-400">Applies to</p>
      <AppliesToBadges bestPractice={bestPractice} />
    </div>
    <div
      class={cn(
        additionalInfoContainerStyles,
        "md:max-[1200px]:items-start min-[1200px]:items-end",
      )}>
      <p class="text-gray-400 whitespace-nowrap">App support</p>
      {
        allBenchmarksPending ? (
          <p class="text-base leading-normal font-semibold text-white">
            Pending
          </p>
        ) : (
          <ScoreBar score={appSupport} mobileAdaptive={false} />
        )
      }
    </div>
  </Fragment>
</SubpageHero>
<section
  class="w-full box-border h-fit flex flex-col flex-nowrap justify-start items-center py-6 sm:py-[60px] px-5 sm:px-8">
  <div
    class="w-full max-w-[1216px] flex flex-nowrap flex-col md:flex-row gap-6 md:gap-20 justify-start md:justify-center items-start">
    <BestPracticeTechnicalDetails bestPractice={bestPractice} />
    <div class="w-full md:w-1/2 h-fit box-border flex flex-col gap-5">
      <SuggestionCard
        client:only="react"
        sidebarVariant
        whatsSuggested="best practice"
        allContributions={allContributions}
        gitHubTargetHref={`https://github.com/namehash/ensawards/blob/main/ensawards.org/data/ens-best-practices/${bestPractice.category.categorySlug}/${bestPractice.bestPracticeSlug}.ts`}>
        <SuggestionCardLoading
          slot="fallback"
          sidebarVariant
          whatsSuggested="best practice"
        />
      </SuggestionCard>
      {
        bestPractice.appliesTo.map((appliesTo) => (
          <BenchmarksPerAppTypeCard
            key={`benchmarks-list-${appliesTo}`}
            client:load
            appsWithBenchmark={sortedAppsByBenchmark.filter(
              ({ app }) => app.type === appliesTo,
            )}
          />
        ))
      }
    </div>
  </div>
</section>
