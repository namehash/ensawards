---
import { ContactForm } from "../molecules/contact-form/ContactForm";
import { ContactFormField, PossibleSuggestions } from "../molecules/contact-form/types";

export interface ModalProps {
  overlayId: string;
}

const { overlayId }: ModalProps = Astro.props;
---

<modal-content
  id=`${overlayId}-modal-content`
  data-id={overlayId}
  class="w-fit sm:min-w-[420px] max-w-[460px] h-fit box-border p-6 flex flex-nowrap flex-col justify-start items-start gap-5 shrink-0 rounded-xl bg-white">
  <slot name="modalContent" />
</modal-content>

<script>
  function closeOverlay(overlayId: string) {
    document.querySelector(`#${overlayId}`).classList.add("hidden");
    document.body.classList.remove("no-scroll");

    const scrollToY = parseInt(
      document.body.style.top.replace("px", "").replace("-", ""),
    );
    document.body.style.top = "";

    if (!isNaN(scrollToY)) {
      window.scrollTo({ top: scrollToY, behavior: "instant" });
    }
  }

  function enableAlternativeClosings(overlayId: string) {
    const overlay = document.querySelector(`#${overlayId}`);
    const content = overlay.querySelector(`#${overlayId}-modal-content`);

    // Close on click outside
    overlay.addEventListener("click", (e) => {
      if (!content.contains(e.target)) closeOverlay(overlayId);
    });

    // Close on Escape key
    // Currently this event fires multiple cause there are multiple overlays always in DOM
    // TODO: for now it's fixed in a 'hacky' way in the closeOverlay function
    // - figure out if there is a more elegant way to do it
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        e.preventDefault();
        closeOverlay(overlayId);
      }
    });
  }

  class OverlayContent extends HTMLElement {
    connectedCallback() {
      enableAlternativeClosings(this.dataset.id);
    }
  }

  customElements.define("modal-content", OverlayContent);
</script>
