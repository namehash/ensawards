---
import { cn } from "@/utils/tailwindClassConcatenation";
import { shadcnButtonVariants } from "@/components/ui/shadcnButtonStyles";
import NotFoundErrorCode from "@/assets/404.svg";

interface Error404DisplayProps {
  header: string;
  description: string;
  button: {
    text: string;
    href: string;
  };
}

const { header, description, button }: Error404DisplayProps = Astro.props;
---

<section class="w-full h-screen flex justify-center items-center">
  <div
    class="h-fit w-fit max-w-[850px] flex flex-nowrap flex-col justify-center items-center gap-8">
    <img
      src={NotFoundErrorCode.src}
      alt="404 error"
      class="h-[90px] sm:h-[200px] sm:pl-[26px] sm:pr-[28px] sm:pt-[21px]"
    />
    <div
      class="h-fit w-fit flex flex-nowrap flex-col justify-center items-center gap-5 max-sm:px-5">
      <div
        class="h-fit w-fit flex flex-nowrap flex-col justify-center items-center gap-3">
        <h1
          class="text-2xl sm:text-4xl leading-8 sm:leading-normal font-semibold text-center">
          {header}
        </h1>
        <p
          class="text-base sm:text-sm leading-6 sm:leading-normal font-normal text-gray-500 text-center">
          {description}
        </p>
      </div>
      <a
        href={button.href}
        class={cn(
          shadcnButtonVariants({
            variant: "outline",
            size: "default",
            className: "cursor-pointer rounded-full",
          }),
        )}>{button.text}</a
      >
    </div>
  </div>
</section>
