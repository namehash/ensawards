---
import CircularScore from "../CircularScore.astro";
import { type EnsAwardsScore } from "@/utils/types";

export interface EnsAwardsScoreProps {
  score: EnsAwardsScore;
  label: string;
  scorePending?: boolean;
}

const { score, label, scorePending = false }: EnsAwardsScoreProps = Astro.props;
---

<div
  class="max-w-[228px] max-h-[232px] box-border flex flex-col justify-center items-center gap-[14px] pt-[32px] pb-[23px] px-[44px] bg-[linear-gradient(180deg,#191D4D_0%,#10143F_100%)] rounded-2xl border border-white/10 relative z-10">
  <CircularScore score={score} scorePending={scorePending} />
  <p class="text-base leading-normal font-semibold text-white">{label}</p>
</div>
