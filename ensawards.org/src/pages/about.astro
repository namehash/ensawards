---
import { Image } from "astro:assets";
import AboutImage from "../assets/awardImage.svg";
import SubpageHero from "../components/molecules/SubpageHero.astro";
import Layout from "../layouts/Layout.astro";

const descriptionStyles = "text-base leading-7 font-normal text-gray-500 self-stretch";
---

<Layout>
  <SubpageHero header="About" />
  <section
    class="w-full box-border h-fit flex flex-col flex-nowrap justify-center items-center gap-10 p-5 sm:py-[60px] sm:px-8">
    <div
      class="w-full max-w-[1216px] box-border h-fit flex flex-col min-[900px]:flex-row flex-nowrap justify-start sm:justify-center items-center gap-10">
      <Image
        alt="about ENSAwards"
        src={AboutImage}
        quality={100}
        class="min-[900px]:hidden block"
      />
      <div
        class="w-full min-[900px]:w-1/2 h-fit flex flex-nowrap flex-col justify-start items-start gap-3">
        <h3 class="text-2xl leading-none font-semibold text-black">
          Recognizing Best-in-Class ENS Integrations
        </h3>
        <p class={descriptionStyles}>
          ENSAwards recognizes wallets and web3 apps that totally crush their ENS integrations.
          It checks how well products handle ENS features—including tricky edge cases that often break stuff—to spotlight apps giving users insanely great experiences.
          Through rankings and public shoutouts, ENSAwards showcases products that nail ENS functionality and demonstrate best practices.
          Most importantly, It gives teams honest feedback on improving integrations and showing others how it's done.
        </p>
        <h4 class="text-lg leading-normal font-semibold text-black">Flex Your Integration Game</h4>
        <p class={descriptionStyles}>
          ENSAwards runs purely on community recognition and social credit as motivation for building solid products.
          There's no cash involved—it's all about earning respect and visibility within the web3 community.
          The real win is getting recognized for building genuinely good ENS integrations that raise the bar.
          By calling out great work and celebrating the exceptional engineering, ENSAwards makes everyone want to build better stuff.
          ENSAwards is created and maintained by NameHash Labs, and is not an official product of the ENS DAO.
        </p>
      </div>
      <Image
        alt="about ENSAwards"
        src={AboutImage}
        quality={100}
        class="hidden min-[900px]:block max-w-1/2"
      />
    </div>
  </section>
</Layout>
