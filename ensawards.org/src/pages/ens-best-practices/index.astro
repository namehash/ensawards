---
import UnderConstructionBanner from "@/components/atoms/banners/UnderConstructionBanner.astro";
import ItemsList from "@/components/molecules/ItemsList.astro";
import SubpageHero from "@/components/molecules/SubpageHero.astro";
import { BEST_PRACTICE_CATEGORIES } from "data/ens-best-practices";
import Layout from "@/layouts/Layout.astro";
import { CategoryStatuses } from "data/ens-best-practices/types";
import { getBestPracticesByCategory } from "data/ens-best-practices/utils";
import BestPracticeCard from "@/components/atoms/cards/BestPracticeCard.astro";
---

<Layout
  pageMetadata={{
    title: "ENSAwards: ENS Best Practices",
    description: "Best practices for ENS integrations.",
    url: "https://ensawards.org/ens-best-practices",
  }}>
  <SubpageHero
    header="ENS best practices"
    description="Learn how to build the best possible ENS integration."
  />
  <section
    class="w-full box-border h-fit flex flex-col flex-nowrap justify-start items-center max-sm:gap-6 gap-10 p-5 sm:py-[60px] sm:px-8">
    {
      BEST_PRACTICE_CATEGORIES.filter(
        (category) => category.status === CategoryStatuses.Active,
      ).map((category) => (
        <ItemsList
          key={`${category.categorySlug}-group`}
          header={category.name}
          additionalInfo={category.description}>
          {getBestPracticesByCategory(category).map((bestPractice) => (
            <BestPracticeCard
              key={`${category.categorySlug}-${bestPractice.bestPracticeSlug}`}
              bestPractice={bestPractice}
            />
          ))}
        </ItemsList>
      ))
    }
    <UnderConstructionBanner
      text="The current catalog of ENS best practices is not comprehensive and is being expanded."
    />
  </section>
</Layout>
