---
import { type InterpretedName, type Address, asInterpretedName } from "enssdk";

import { AdvocateSearchForm } from "@/components/ens-advocates/AdvocateSearchForm";
import SubpageHero from "@/components/molecules/SubpageHero.astro";
import { shadcnButtonVariants } from "@/components/ui/shadcnButtonStyles";
import Layout from "@/layouts/Layout.astro";
import { cn } from "@/utils/tailwindClassConcatenation";

interface AdvocateIdentity {
  name: InterpretedName;
  ethAddress: Address;
}
const EXAMPLE_ADVOCATES: AdvocateIdentity[] = [
  {
    name: asInterpretedName("vitalik.eth"),
    ethAddress: "0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045",
  },
  {
    name: asInterpretedName("james.eth"),
    ethAddress: "0x6Dc43be93a8b5Fd37dC16f24872BaBc6dA5E5e3E",
  },
  {
    name: asInterpretedName("brantly.eth"),
    ethAddress: "0x983110309620D911731Ac0932219af06091b6744",
  },
  {
    name: asInterpretedName("lightwalker.eth"),
    ethAddress: "0x1a199654959140E5c1A2F4135fAA7Ba2748939C5",
  },
  {
    name: asInterpretedName("grailsmarket.eth"),
    ethAddress: "0x7e491cde0fbf08e51f54c4fb6b9e24afbd18966d",
  },
];
---

<Layout>
  <SubpageHero header="Explore ENS Advocates" />
  <section
    class="w-full box-border h-fit flex flex-col flex-nowrap justify-center items-center max-sm:gap-6 gap-10 py-5 sm:py-[60px] px-5 sm:px-8">
    <div
      class="w-full max-w-[1216px] box-border h-fit flex flex-col justify-start items-start gap-5 sm:gap-8">
      <AdvocateSearchForm client:load />
      <div class="flex flex-col gap-2 justify-center items-start">
        <p class="text-sm leading-normal font-semibold">Examples:</p>
        <div class="flex flex-row flex-wrap justify-start items-center gap-2">
          {
            EXAMPLE_ADVOCATES.map((exampleAdvocate) => (
              <a
                href={`/advocate/${exampleAdvocate.ethAddress}`}
                class={cn(
                  shadcnButtonVariants({
                    variant: "outline",
                    size: "default",
                    className: "rounded-full cursor-pointer",
                  }),
                )}>
                {exampleAdvocate.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
