---
import ReferralLiveFeedHeroImage from "../../assets/referralLiveFeedHeroImage.png";
import SubpageHero from "../../components/molecules/SubpageHero.astro";
import { LiveReferralFeed } from "../../components/referral-awards-program/referrals/LiveReferralFeed";
import { shadcnButtonVariants } from "../../components/ui/shadcnButtonStyles";
import Layout from "../../layouts/Layout.astro";
import { cn } from "../../utils/tailwindClassConcatenation";
---

<Layout
  pageMetadata={{
    title: "ENSAwards: ENS referral live feed",
    description: "Watch the latest ENS referrals as they stream in.",
    url: "https://ensawards.org/ens-referral-program/live-feed",
    ogImage: "https://ensawards.org/ens_referral_live_feed_og_image.png",
    twitterImage:
      "https://ensawards.org/ens_referral_live_feed_twitter_og_image.png",
  }}>
  <SubpageHero
    header="ENS referral live feed"
    description="Watch the latest ENS referrals as they stream in."
    breadcrumbs={["ENS Referral Program"]}
    customImage={{
      source: ReferralLiveFeedHeroImage,
      width: 342,
      height: 337,
      styles: "-top-12 right-5 opacity-100 sm:max-[850px]:opacity-40",
    }}>
    <div
      slot="ctaContent"
      class="flex flex-col sm:flex-row justify-start items-start gap-4">
      <a
        href="/ens-referral-program"
        class={cn(
          shadcnButtonVariants({
            variant: "default",
            size: "default",
            className:
              "cursor-pointer rounded-full px-5 h-11 sm:h-[50px] box-border text-black bg-white hover:bg-white/90",
          }),
        )}>Learn about the ENS referral program</a
      >
    </div>
  </SubpageHero>
  <section
    class="w-full box-border h-fit flex flex-col flex-nowrap justify-start items-center max-sm:gap-6 gap-[60px] px-5 py-6 sm:py-[80px] sm:px-8">
    <div class="w-full max-w-[1216px] h-fit">
      <LiveReferralFeed
        client:load
        title={{
          text: "Latest referrals",
          styles: {
            container:
              "w-full flex flex-col sm:flex-row sm:flex-wrap justify-start sm:justify-between items-start sm:items-center gap-y-2",
            text: "text-2xl leading-normal font-semibold",
          },
        }}
        recordsPerPage={50}
      />
    </div>
  </section>
</Layout>
