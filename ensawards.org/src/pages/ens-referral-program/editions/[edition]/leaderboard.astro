---
import Error404Display from "@/components/molecules/Error404Display.astro";
import Layout from "@/layouts/Layout.astro";
import SubpageHero from "@/components/molecules/SubpageHero.astro";
import LeaderboardsHeroImage from "@/assets/leaderboardsHeroImage.png";
import { ReferralProgramEditionHeroCardPieSplit } from "@/components/atoms/cards/referralProgramEditionCard/pie-split/hero";
import { ReferralProgramEditionHeroCardRevShareLimit } from "@/components/atoms/cards/referralProgramEditionCard/rev-share/hero";
import { ReferralProgramAwardModels } from "@namehash/ens-referrals/v1";
import { ReferrerLeaderboard } from "@/components/referral-awards-program/referrers/ReferrerLeaderboard";
import { getReferralProgramEditionSummaryBySlug } from "@/utils/referralProgram";
import { ReferralProgramLeaderboardHeroButtons } from "@/components/atoms/ReferralProgramLeaderboardHeroButtons";

export const prerender = false;

const { edition } = Astro.params;

const resolvedReferralProgramEditionSummary = await getReferralProgramEditionSummaryBySlug(edition);

// If the referral program edition summary cannot be found based on the slug in the URL,
// set the 404 status explicitly for SEO/caching purposes and render the 404 fallback.
if (resolvedReferralProgramEditionSummary === undefined) {
  Astro.response.status = 404;
}
---

{
  resolvedReferralProgramEditionSummary === undefined ? (
    <Layout
      isStatic={true}
      pageMetadata={{
        title: `ENSAwards: Unrecognized ENS Referral Program Edition`,
        description: `The requested ENS Referral Program edition is not recognized.`,
        url: `https://ensawards.org/ens-referral-program/editions/${edition}/leaderboard`,
      }}>
      <Error404Display
        header="Unrecognized ENS Referral Program Edition"
        description="The requested ENS Referral Program edition is not recognized."
        button={{
          text: "View all ENS Referral Program editions",
          href: "/ens-referral-program/editions",
        }}
      />
    </Layout>
  ) : (
    <Layout
      pageMetadata={{
        title: `ENSAwards: ENS Leaderboard for ${resolvedReferralProgramEditionSummary.displayName} Referrers`,
        description: `Compare referrers by their performance in ${resolvedReferralProgramEditionSummary.displayName}.`,
        url: `https://ensawards.org/ens-referral-program/editions/${resolvedReferralProgramEditionSummary.slug}/leaderboard`,
        ogImage: `https://ensawards.org/${resolvedReferralProgramEditionSummary.slug}_referral_program_edition_og_image.png`,
        twitterImage: `https://ensawards.org/${resolvedReferralProgramEditionSummary.slug}_referral_program_edition_twitter_og_image.png`,
      }}>
      <SubpageHero
        header={`${resolvedReferralProgramEditionSummary.displayName} leaderboard`}
        description={`Compare referrers by their performance in ${resolvedReferralProgramEditionSummary.displayName}.`}
        breadcrumbs={["ENS Referral Program"]}
        customImage={{
          source: LeaderboardsHeroImage,
          width: 371,
          height: 372,
          styles: "-top-0 right-0 opacity-10",
        }}>
        {resolvedReferralProgramEditionSummary.rules.awardModel ===
        ReferralProgramAwardModels.RevShareLimit ? (
          <ReferralProgramEditionHeroCardRevShareLimit
            client:load
            slot="largerHeroItem"
            referralProgramEditionSummary={
              resolvedReferralProgramEditionSummary
            }
          />
        ) : (
          <ReferralProgramEditionHeroCardPieSplit
            client:load
            slot="largerHeroItem"
            referralProgramEditionSummary={
              resolvedReferralProgramEditionSummary
            }
          />
        )}
        <div
          slot="ctaContent"
          class="flex flex-col gap-4 justify-start items-start">
          <ReferralProgramLeaderboardHeroButtons
            client:load
            referralProgramEditionSummary={
              resolvedReferralProgramEditionSummary
            }
          />
          <div class="block md:hidden bg-white/15 h-[1px] w-[calc(100vw-48px)]" />
        </div>
      </SubpageHero>
      <section class="w-full box-border h-fit flex flex-col flex-nowrap justify-start items-center max-sm:gap-6 gap-10 p-5 sm:py-[60px] sm:px-8">
        <ReferrerLeaderboard
          client:load
          referralProgramEditionSummary={resolvedReferralProgramEditionSummary}
        />
      </section>
    </Layout>
  )
}
