---
import { Image } from "astro:assets";
import ReferralImage from "../assets/referralImage.svg";
import SubpageHero from "../components/molecules/SubpageHero.astro";
import Layout from "../layouts/Layout.astro";

const descriptionStyles = "text-base leading-7 font-normal text-gray-500 self-stretch";
---

<Layout>
  <SubpageHero header="ENS Referral Program" />
  <section
    class="w-full box-border h-fit flex flex-col flex-nowrap justify-center items-center gap-10 p-5 sm:py-[60px] sm:px-8">
    <div
      class="w-full max-w-[1216px] box-border h-fit flex flex-col min-[900px]:flex-row flex-nowrap justify-start sm:justify-center items-center sm:items-start gap-10">
      <Image
        alt="ENS Referral Program"
        src={ReferralImage}
        quality={100}
        class="min-[900px]:hidden block"
      />
      <div
        class="w-full min-[900px]:w-1/2 h-fit flex flex-nowrap flex-col justify-start items-start gap-3">
        <h3 class="text-2xl leading-none font-semibold text-black">
          Accelerate ENS Growth
        </h3>
        <p class={descriptionStyles}>
          Coming with ENSv2—a referral program designed to accelerate ENS DAO
          revenue and supercharge ENS adoption. The program incentivizes
          registrars, gaming applications, wallet providers, and other
          user-facing organizations with $ENS token rewards to drive name
          registrations across their communities.
        </p>
        <h4 class="text-lg leading-normal font-semibold text-black">
          Win-Win Economics
        </h4>
        <p class={descriptionStyles}>
          Here's the play: ENS DAO keeps 100% of registration fees while
          top-performing partners stack $ENS tokens. No revenue splitting—just
          pure upside for ENS growth with governance power flowing to the
          builders actually moving the needle.
        </p>
        <h4 class="text-lg leading-normal font-semibold text-black">
          The Vision
        </h4>
        <p class={descriptionStyles}>
          Build an unstoppable growth machine where ENS DAO income and adoption
          explode together. When growth and governance align, magic happens.
          Partners don't just promote ENS—they become owners with real stakes,
          naturally championing ENS across every corner of web3.
          <br /><br />
          Coming soon with ENSv2. Learn more at <a
            href="https://github.com/namehash/ens-v2-referral-programs"
            target="_blank"
            rel="noreferrer noopener"
            class="underline underline-offset-[25%] decoration-from-font duration-200 transition-all hover:text-black"
            >ENSv2 Referral Programs</a
          >.
        </p>
      </div>
      <Image
        alt="ENS Referral Program"
        src={ReferralImage}
        quality={100}
        class="hidden min-[900px]:block max-w-1/2"
      />
    </div>
  </section>
</Layout>
