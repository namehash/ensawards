---
import Layout from "@/layouts/Layout.astro";
import SubpageHero from "@/components/molecules/SubpageHero.astro";
import { BEST_PRACTICE_CATEGORIES } from "/data/ens-best-practices";
import { type BestPracticeApp } from "/data/ens-best-practices/types";
import { APPS } from "/data/apps";
import { type App } from "/data/apps/types";
import { getAppBySlug } from "/data/apps/utils.ts";
import {
  getBestPracticesByCategory,
  getBestPracticeBySlug,
} from "/data/ens-best-practices/utils.ts";
import DataLoadingError from "@/components/organisms/DataLoadingError.astro";
import BenchmarkResultHeroBadge from "@/components/atoms/badges/BenchmarkResultHeroBadge.astro";
import { type AppBenchmark } from "/data/apps/benchmarks-types";
import { SuggestionCard } from "@/components/atoms/cards/SuggestionCard.tsx";
import BestPracticeTechnicalDetails from "@/components/molecules/BestPracticeTechnicalDetails.astro";
import BenchmarkSummaryCard from "@/components/atoms/cards/BenchmarkSummaryCard.astro";
import { cn } from "@/utils/tailwindClassConcatenation";
import { AppSummaryCard } from "@/components/atoms/cards/AppSummaryCard.tsx";

export function getStaticPaths() {
  const staticPaths = [];

  for (let category of BEST_PRACTICE_CATEGORIES) {
    getBestPracticesByCategory(category).forEach((bestPractice: BestPracticeApp) => {
      const applicableApps = APPS.filter(
        (app: App) =>
          bestPractice.appliesTo.includes(app.type) &&
          app.benchmarks.some(
            (benchmark: AppBenchmark) => benchmark.bestPractice.id === bestPractice.id,
          ),
      );

      applicableApps.forEach((app: App) =>
        staticPaths.push({
          params: {
            category: category.categorySlug,
            bestPractice: bestPractice.bestPracticeSlug,
            app: app.appSlug,
          },
        }),
      );
    });
  }
  return staticPaths;
}

const { category, bestPractice, app } = Astro.params;

const resolvedBestPractice = getBestPracticeBySlug(bestPractice);
const resolvedApp = getAppBySlug(app);

let AppIcon;
let appBenchmark;

if (resolvedApp !== undefined && resolvedBestPractice !== undefined) {
  AppIcon = resolvedApp.icon;
  appBenchmark = resolvedApp.benchmarks.find(
    (benchmark: AppBenchmark) => benchmark.bestPractice.id === resolvedBestPractice.id,
  );
}
---

{
  resolvedBestPractice === undefined ||
  resolvedApp === undefined ||
  appBenchmark === undefined ? (
    // theoretically, because of Astro's build-time page generation, this should never happen
    <DataLoadingError />
  ) : (
    <Layout
      pageMetadata={{
        title: `ENSAwards: ${resolvedApp.name} benchmark details for "${resolvedBestPractice.name}" best practice`,
        description: `See how well ${resolvedApp.name} applies "${resolvedBestPractice.name}" best practice`,
        url: `https://ensawards.org/app/${app}/${category}/${bestPractice}`,
      }}>
      <SubpageHero
        header={resolvedBestPractice.name}
        description={resolvedBestPractice.description}
        breadcrumbs={[
          "ENS leaderboards",
          `${resolvedApp.type} leaderboard`,
          resolvedApp.name,
        ]}>
        <div slot="icon" class="flex flex-row gap-3 justify-start items-center">
          <AppIcon className="w-[28px] h-[28px] shrink-0 rounded-[6px]" />
          <p class="text-base leading-normal font-medium text-white">
            {resolvedApp.name}
          </p>
        </div>
        <BenchmarkResultHeroBadge
          benchmark={appBenchmark}
          slot="largerHeroItem"
        />
      </SubpageHero>
      <section class="w-full box-border h-fit flex flex-col flex-nowrap justify-start items-center p-5 gap-5 sm:gap-10 sm:py-[60px] sm:px-8">
        <div class="w-full max-w-[1216px] box-border h-fit flex flex-col-reverse lg:flex-row lg:flex-nowrap justify-start lg:justify-between items-center sm:items-start gap-6 sm:gap-10 lg:gap-20">
          <div class="lg:hidden block w-full">
            <AppSummaryCard client:load app={resolvedApp} />
          </div>
          <BestPracticeTechnicalDetails bestPractice={resolvedBestPractice} />
          <div class="w-full lg:w-1/3 h-fit box-border flex flex-col gap-5">
            <BenchmarkSummaryCard benchmark={appBenchmark}>
              <div slot="appInfo" class="flex h-7 items-center gap-3">
                <AppIcon className="w-[28px] h-[28px] shrink-0 rounded-[6px]" />
                <a
                  target="_self"
                  href={`/app/${resolvedApp.appSlug}`}
                  class={cn(
                    "text-sm leading-normal font-medium text-black",
                    "underline decoration-black/40 decoration-from-font underline-offset-[25%]",
                    "transition-all duration-200 hover:decoration-black",
                  )}>
                  {resolvedApp.name}
                </a>
              </div>
            </BenchmarkSummaryCard>
            <SuggestionCard
              client:load
              sidebarVariant
              whatsSuggested="best practice"
              allContributions={resolvedBestPractice.contributions}
              gitHubTargetHref={`https://github.com/namehash/ensawards/blob/main/ensawards.org/data/ens-best-practices/${resolvedBestPractice.category.categorySlug}/${resolvedBestPractice.bestPracticeSlug}.ts`}
            />
            <div class="hidden lg:block w-full">
              <AppSummaryCard client:load app={resolvedApp} />
            </div>
          </div>
        </div>
      </section>
    </Layout>
  )
}
