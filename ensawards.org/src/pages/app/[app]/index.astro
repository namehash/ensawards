---
import { EnsIcon, TwitterIcon } from "@namehash/namehash-ui";

import {
  BenchmarkResultBadge,
  benchmarkResultToBadgeStyles,
} from "@/components/atoms/badges/BenchmarkResultBadge";
import BenchmarkResultCard from "@/components/atoms/cards/BenchmarkResultCard.astro";
import EnsAwardsScore from "@/components/atoms/ens-awards-score/circular.astro";
import GlobeIcon from "@/components/atoms/icons/GlobeIcon.astro";
import ItemsList from "@/components/molecules/ItemsList.astro";
import SubpageHero from "@/components/molecules/SubpageHero.astro";
import DataLoadingError from "@/components/organisms/DataLoadingError.astro";
import { APPS } from "data/apps";
import Layout from "@/layouts/Layout.astro";
import { calcAppEnsAwardsScore, getAppBySlug, buildAppOgImageUrlHref } from "data/apps/utils.ts";
import {
  ContributorsCard,
  ContributorsCardLoading,
} from "@/components/atoms/cards/ContributorsCard.tsx";
import { type Contribution } from "data/contributors/types.ts";
import { type EnsAwardsScore as EnsAwardsScoreType } from "@/components/atoms/ens-awards-score/types.ts";
import { cn } from "@/utils/tailwindClassConcatenation";
import {
  groupBenchmarksByCategory,
  calcCategoryScore,
  compareBenchmarks,
} from "data/apps/benchmarks-utils";
import { type EffectiveAppBenchmark } from "data/apps/benchmarks-types";
import { EnsAwardsCircularScoreSmall } from "@/components/atoms/ens-awards-score/circular-small.tsx";
import { getAppContributions } from "data/contributors/utils.ts";

export function getStaticPaths() {
  return APPS.map((app) => ({ params: { app: app.appSlug } }));
}

const { app } = Astro.params;

const appToDisplay = getAppBySlug(app);

let appScore: EnsAwardsScoreType = 0;
let AppIcon;
let appBenchmarksDataContributions: Contribution[] = [];
let benchmarkGroups: EffectiveAppBenchmark[][] = [];

if (appToDisplay !== undefined) {
  appScore = calcAppEnsAwardsScore(appToDisplay);
  AppIcon = appToDisplay.icon;
  appBenchmarksDataContributions = getAppContributions(appToDisplay);

  benchmarkGroups = groupBenchmarksByCategory(appToDisplay.benchmarks);
}
---

{
  appToDisplay === undefined ? (
    // theoretically, because of Astro's build-time page generation, this should never happen
    <DataLoadingError />
  ) : (
    <Layout
      pageMetadata={{
        title: `ENSAwards: ${appToDisplay.name} ENS Integration Benchmarks`,
        description: appToDisplay.description,
        url: `https://ensawards.org/app/${app}`,
        ogImage: buildAppOgImageUrlHref(appToDisplay.ogImagePath),
        twitterImage: buildAppOgImageUrlHref(appToDisplay.twitterOgImagePath),
      }}>
      <SubpageHero
        header={appToDisplay.name}
        description={appToDisplay.description}
        breadcrumbs={[
          { text: "ENS leaderboards", linkHref: "/leaderboards" },
          {
            text: `${appToDisplay.type} leaderboard`,
            linkHref: `/leaderboards/${appToDisplay.type.toLowerCase()}`,
          },
        ]}>
        <AppIcon
          slot="icon"
          className="w-[60px] h-[60px] shrink-0 rounded-lg"
        />
        <div
          slot="ctaContent"
          class="flex flex-row flex-nowrap justify-start items-center gap-2">
          <a
            href={appToDisplay.socials.website}
            rel="noreferrer"
            target="_blank">
            <GlobeIcon className="hover:text-white text-gray-400 transition-all duration-200" />
          </a>
          <a
            href={appToDisplay.socials.twitter}
            rel="noreferrer"
            target="_blank">
            <TwitterIcon className="hover:text-white text-gray-400 transition-all duration-200" />
          </a>
          {appToDisplay.socials.ens && (
            <a
              href={`https://app.ens.domains/${encodeURIComponent(appToDisplay.socials.ens)}`}
              rel="noreferrer"
              target="_blank">
              <EnsIcon
                width={18}
                height={18}
                className="hover:text-white text-gray-400 transition-all duration-200"
              />
            </a>
          )}
        </div>
        <EnsAwardsScore
          slot="largerHeroItem"
          score={appScore}
          label="ENSAwards score"
        />
      </SubpageHero>
      <section class="w-full box-border h-fit flex flex-col flex-nowrap justify-start items-center p-5 gap-5 sm:gap-10 sm:py-[60px] sm:px-8">
        <div class="w-full max-w-[1216px] flex flex-col md:flex-row justify-start md:justify-between gap-6 items-center md:items-start">
          <div class="w-full md:w-3/5">
            <ItemsList header="ENS best practice benchmarks">
              {benchmarkGroups.map((group) => {
                const categoryScore = calcCategoryScore(group);
                return (
                  <div class="w-full flex flex-col justify-start items-start gap-2">
                    <div class="w-full flex flex-row items-center justify-start gap-3 pb-2">
                      <EnsAwardsCircularScoreSmall score={categoryScore} />
                      {/* This assumption is safe, because all benchmarks passed into this component belong to one BestPracticeCategory */}
                      <span class="flex-1 text-lg leading-normal font-semibold text-black">
                        {group[0].bestPractice.category.name}
                      </span>
                    </div>
                    {[...group]
                      .sort((a, b) => compareBenchmarks(a, b))
                      .map((benchmark: EffectiveAppBenchmark) => (
                        <BenchmarkResultCard
                          name={benchmark.bestPractice.name}
                          notes={benchmark.bestPractice.description}
                          viewDetails={{
                            text: "View detailed report",
                            link: `/app/${appToDisplay.appSlug}/${benchmark.bestPractice.category.categorySlug}/${benchmark.bestPractice.bestPracticeSlug}`,
                          }}>
                          <BenchmarkResultBadge
                            slot="badge"
                            className={cn(
                              benchmarkResultToBadgeStyles(benchmark),
                              "cursor-pointer",
                            )}
                            benchmark={benchmark}
                          />
                        </BenchmarkResultCard>
                      ))}
                  </div>
                );
              })}
            </ItemsList>
          </div>
          <div class="w-full md:w-2/5">
            <ContributorsCard
              client:only="react"
              whatsSuggested="benchmark result"
              allContributions={appBenchmarksDataContributions}
              gitHubTargetHref={`https://github.com/namehash/ensawards/blob/main/ensawards.org/data/apps/${appToDisplay.appSlug}/benchmarks.ts`}
              sidebarVariant>
              <ContributorsCardLoading
                slot="fallback"
                sidebarVariant
                whatsSuggested="benchmark result"
              />
            </ContributorsCard>
          </div>
        </div>
      </section>
    </Layout>
  )
}
