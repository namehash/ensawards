---
import Layout from "@/layouts/Layout.astro";
import SubpageHero from "@/components/molecules/SubpageHero.astro";
import LeaderboardsHeroImage from "@/assets/leaderboardsHeroImage.png";
import AwardDistributionsHeader from "@/components/contract-naming-season/award-distributions/AwardDistributionsHeader.astro";
import { AwardDistributionsList } from "@/components/contract-naming-season/award-distributions/AwardDistributionsList";
import { ContractNamingSeasonAwardCardLoading } from "@/components/atoms/cards/contractNamingSeasonAwardCard/loading.tsx";
---

<Layout
  pageMetadata={{
    title: "ENSAwards: ENS Contract Naming Season Award Distributions",
    description: "Check out all the awards distributed to date.",
    url: "https://ensawards.org/ens-contract-naming-season/award-distributions",
    ogImage:
      "https://ensawards.org/contract-naming-season-award-distributions_og.png",
    twitterImage:
      "https://ensawards.org/contract-naming-season-award-distributions_twitter_og.png",
  }}>
  <SubpageHero
    header="ENS Contract Naming Season Award Distributions"
    description="Check out all the awards distributed to date."
    breadcrumbs={[
      {
        text: "ENS Contract Naming Season",
        linkHref: "/ens-contract-naming-season",
      },
    ]}
    customImage={{
      source: LeaderboardsHeroImage,
      width: 371,
      height: 277,
      styles: "-top-10 right-0",
    }}
  />
  <section
    class="w-full box-border h-fit flex flex-col flex-nowrap justify-start items-center max-sm:gap-6 gap-10 p-5 sm:py-[60px] sm:px-8">
    <div
      class="w-full max-w-[1216px] h-fit flex flex-col justify-start items-start gap-6">
      <AwardDistributionsHeader />
      <AwardDistributionsList client:only="react">
        <div
          slot="fallback"
          class="w-full flex flex-col justify-start items-center gap-2">
          {
            Array.from({ length: 30 }).map((_, index) => (
              <ContractNamingSeasonAwardCardLoading key={index} />
            ))
          }
        </div>
      </AwardDistributionsList>
    </div>
  </section>
</Layout>
