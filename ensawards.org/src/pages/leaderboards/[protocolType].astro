---
import { formatBestPracticeTarget } from "data/ens-best-practices/utils.ts";
import type { ImageMetadata } from "astro";
import LeaderboardsHeroImage from "@/assets/leaderboardsHeroImage.png";
import { ProtocolTypes } from "data/protocols/types.ts";
import DataLoadingError from "@/components/organisms/DataLoadingError.astro";
import type { ProtocolId } from "data/protocols/types.ts";
import SubpageHero from "@/components/molecules/SubpageHero.astro";
import Layout from "@/layouts/Layout.astro";
import LeaderboardCard from "@/components/atoms/cards/LeaderboardCard.astro";
import { Image } from "astro:assets";
import ItemsList from "@/components/molecules/ItemsList.astro";
import { getContractNamingScoresByProtocolType } from "@/contract-pipelines/utils.ts";
import { getProtocolById, asProtocolType, formatProtocolType } from "data/protocols/utils.ts";
import {
  ContributorsCard,
  ContributorsCardLoading,
  ContributionTypes,
} from "@/components/atoms/cards/ContributorsCard";
import type { Contribution } from "data/contributors/types";
import { getProtocolContributions } from "data/contributors/utils";
import { type EnsAwardsScore } from "data/shared/ens-awards-score.ts";

export function getStaticPaths() {
  return Object.values(ProtocolTypes).map((protocolType) => ({
    params: { protocolType: protocolType },
  }));
}

const { protocolType: maybeProtocolType } = Astro.params;

const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/*.{jpeg,jpg,png,gif,svg}");
const placeIcons = [
  "/src/assets/firstPlaceAward.svg",
  "/src/assets/secondPlaceAward.svg",
  "/src/assets/thirdPlaceAward.svg",
];

const protocolType = asProtocolType(maybeProtocolType);

const formattedBestPracticeTarget: string = formatBestPracticeTarget(protocolType, {
  lowercase: false,
  plural: true,
});
const protocolScores: Record<ProtocolId, EnsAwardsScore> =
  getContractNamingScoresByProtocolType(protocolType);
const protocolContractDataContributions: Contribution[] = Object.keys(protocolScores).flatMap(
  (protocolId) => getProtocolContributions(getProtocolById(protocolId as ProtocolId)),
);
---

<Layout
  pageMetadata={{
    title: `ENSAwards: ENS Leaderboard for ${formatProtocolType(protocolType, { lowercase: false })} Integrations`,
    description: `See how ${formattedBestPracticeTarget} score on ENS integration benchmarks.`,
    url: `https://ensawards.org/leaderboards/${protocolType}`,
    ogImage: `https://ensawards.org/${protocolType}_leaderboard_og_image.png`,
    twitterImage: `https://ensawards.org/${protocolType}_leaderboard_twitter_og_image.png`,
  }}>
  <SubpageHero
    header={`${formatProtocolType(protocolType, { lowercase: false })} leaderboard`}
    description={`Compare ${formattedBestPracticeTarget} by their rank of following a selection of ENS best practices.`}
    breadcrumbs={[{ text: "ENS leaderboards", linkHref: "/leaderboards" }]}
    customImage={{
      source: LeaderboardsHeroImage,
      width: 371,
      height: 277,
      styles: "-top-10 right-0",
    }}
  />
  <section
    class="w-full box-border h-fit flex flex-col flex-nowrap justify-start items-center max-sm:gap-6 gap-10 p-5 sm:py-[60px] sm:px-8">
    <div
      class="w-full max-w-[1216px] flex flex-col md:flex-row justify-start md:justify-between gap-6 items-center md:items-start">
      <div class="w-full md:w-3/5">
        <ItemsList containerStyles="gap-3 sm:gap-3">
          {
            [...Object.entries(protocolScores)].map(
              ([scoredProtocolId, value], idx) => {
                // Type casting is necessary due to `Record`'s type nature.
                // We are completely sure of its correctness
                const protocolId = scoredProtocolId as ProtocolId;
                const protocol = getProtocolById(protocolId);
                const ProtocolIcon = protocol.icon;
                return (
                  <LeaderboardCard
                    key={`leaderboard-card-${protocol.protocolSlug}`}
                    name={protocol.name}
                    ensAwardsScore={value}
                    viewDetailsHref={`/protocol/${protocol.protocolSlug}`}
                    viewDetailsText={`${formatProtocolType(protocolType, { lowercase: false })}${protocolType !== ProtocolTypes.DAO ? " protocol" : ""} report`}>
                    {idx < 3 ? (
                      <Image
                        alt={`${idx + 1}-place`}
                        src={images[placeIcons[idx]]()}
                        slot="placeIcon"
                      />
                    ) : (
                      <p
                        slot="placeIcon"
                        class="w-8 pt-[7px] px-[11px] pb-[5px] text-sm leading-normal font-semibold text-muted-foreground">
                        {idx + 1}
                      </p>
                    )}
                    <ProtocolIcon
                      slot="rankedEntityIcon"
                      className="w-10 h-10 rounded-md"
                    />
                  </LeaderboardCard>
                );
              },
            )
          }
        </ItemsList>
      </div>
      <div class="w-full md:w-2/5">
        <ContributorsCard
          client:only="react"
          contributionType={ContributionTypes.Protocol}
          existingContributions={protocolContractDataContributions}
          gitHubTargetHref="https://github.com/namehash/ensawards/blob/main/ensawards.org/data/protocols/index.ts"
          sidebarVariant>
          <ContributorsCardLoading
            slot="fallback"
            sidebarVariant
            contributionType={ContributionTypes.Protocol}
          />
        </ContributorsCard>
      </div>
    </div>
  </section>
</Layout>
)
